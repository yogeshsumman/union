---
import Card from "#/components/Card.astro";
import type { LocalAsset } from "#/lib/types.ts";

interface Props {
  person: {
    twitterHandle: string;
    twitterPicture: LocalAsset | null;
    name: string;
    profilePicture: LocalAsset | null;
    title: string;
  };
}

const { person } = Astro.props;
---

<Card hoverScale>
  <a
    href={`https://x.com/${person.twitterHandle}`}
    target="_blank"
    rel="noopener noreferrer"
    class="flex flex-col group"
  >
    <div class="object-cover overflow-hidden relative">
      <!-- Default profile picture -->
      <div
        class="transition-opacity duration-300 ease-in-out group-hover:opacity-0"
      >
        {
          person.profilePicture?.path ? (
            <img
              class="w-full aspect-[1/1]"
              src={person.profilePicture.path}
              alt={`${person.name} - Union worker`}
            />
          ) : (
            <div class="bg-neutral-900 aspect-1 w-full" />
          )
        }
      </div>

      <!-- Twitter picture or grey background that shows on hover -->
      <div
        class="absolute inset-0 opacity-0 transition-opacity duration-300 ease-in-out group-hover:opacity-100"
      >
        {
          person.twitterPicture?.path ? (
            <img
              class="w-full h-full object-cover"
              src={person.twitterPicture.path}
              alt={`${person.name} - Twitter profile`}
            />
          ) : (
            <div class="bg-gray-600 w-full h-full" />
          )
        }
      </div>
    </div>
    <div class="leading-tight flex flex-col gap p-2 sm:p-4 uppercase font-mono">
      <h1 class="text-2xl font-bold font-supermolot uppercase">
        {person.name}
      </h1>
      <div class="text-gray-400">{person.title}</div>
      <div class="text-accent block">
        @{person.twitterHandle}
      </div>
    </div>
  </a>
</Card>

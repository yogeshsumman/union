---
import { getEntry, render } from "astro:content"
import ContainedSection from "../components/ContainedSection.astro"
import AnimationLayout from "../layouts/AnimationLayout.astro"

const privacyPolicy = await getEntry("legal", "privacy-policy")
if (!privacyPolicy) {
  throw new Error("Missing local privacy policy content")
}
const { Content } = await render(privacyPolicy)
---

<AnimationLayout
  title={privacyPolicy.data.title}
  text=""
>
  <ContainedSection className="">
    <Content />
  </ContainedSection>
</AnimationLayout>

---
import ContainedSection from "../components/ContainedSection.astro";
import AnimationLayout from "../layouts/AnimationLayout.astro";
import { getEntry, render } from "astro:content";

const airdropTerms = await getEntry("legal", "airdrop-terms-and-conditions");
if (!airdropTerms) {
  throw new Error("Missing local airdrop terms content");
}
const { Content } = await render(airdropTerms);
---

<AnimationLayout title={airdropTerms.data.title} text="">
  <ContainedSection className="">
    <Content />
  </ContainedSection>
</AnimationLayout>
